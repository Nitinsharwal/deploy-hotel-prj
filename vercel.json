{
  "version": 2,
  "builds": [
    {
      "src": "hotel_prj/asgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12",
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "buildCommand": "bash build_files.sh",
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "hotel_prj/asgi.py"
    }
  ]
}
